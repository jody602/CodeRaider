{
  "rules": {
    "sessions": {
      ".read": true,
      ".write": true
    },
    "code_tests": {
      ".read": true,
      ".write": true
    },
    "userRooms": {
      ".read": true,
      ".write": true
    },
    "usernames": {
      ".read": true,
      "$name": {
        ".write": "!data.exists() || (auth != null && data.child('steamId').val() === auth.uid)"
      }
    },
    "users": {
      ".read": true,
      ".write": true
    },
    "playerHistory": {
      ".read": true,
      ".write": true
    }
  }
}
